# Telegram Bot
TELEGRAM_BOT_TOKEN=
# Получить у @BotFather — создать нового бота

# Telegram Chat IDs (кому слать уведомления)
TELEGRAM_ARTEM_CHAT_ID=
TELEGRAM_ZHENYA_CHAT_ID=
# Узнать свой chat_id: написать @userinfobot

# Режим работы
USE_POLLING=true
# true = локальная разработка (без HTTPS)
# false = production сервер (нужен webhook)

# Webhook (только когда USE_POLLING=false)
WEBHOOK_URL=https://ef-bot.chirkov.info/telegram/webhook
WEBHOOK_PORT=3001

# OpenAI (для расшифровки голосовых)
OPENAI_API_KEY=
# Получить на platform.openai.com

# Paperclip
PAPERCLIP_BASE_URL=http://localhost:3100
# URL Paperclip UI

# Окружение
NODE_ENV=development
# development / production
